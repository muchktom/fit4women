<!doctype html>
<html lang="cs">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<link rel="icon" href="{{ '/assets/favicon.svg' | url }}" type="image/svg+xml">
<link rel="icon" href="{{ '/assets/favicon-32.png' | url }}" sizes="32x32" type="image/png">
<link rel="icon" href="{{ '/assets/favicon-16.png' | url }}" sizes="16x16" type="image/png">
<link rel="shortcut icon" href="{{ '/assets/favicon.ico' | url }}">
<link rel="apple-touch-icon" href="{{ '/assets/apple-touch-icon.png' | url }}">
<meta name="theme-color" content="#774bad">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@500;600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap">
<link rel="stylesheet" href="{{ '/assets/styles.css' | url }}">
<script defer src="{{ '/assets/site.js' | url }}"></script>
