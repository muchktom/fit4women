<!-- ===== PŘIHLÁŠENÍ ===== -->
<section id="prihlaseni" class="bg-white">
  <div class="wrap">
    <div class="section-head">
      <div class="eyebrow">První krok</div>
      <h2>Přihlášení na trénink</h2>
      <p>Napiš mi a domluvíme se. <b>První lekce je zdarma.</b> Přijď nezávazně vyzkoušet, jak to u nás chodí.</p>
    </div>
    <form class="form" data-mailform data-to="{{ site.contact.email }}" data-subject="Přihláška na trénink FIT4WOMEN">
      <div class="field">
        <label for="jmeno">Jméno a příjmení</label>
        <input id="jmeno" name="jmeno" data-label="Jméno" type="text" required>
      </div>
      <div class="row2">
        <div class="field">
          <label for="email">E-mail</label>
          <input id="email" name="email" data-label="E-mail" type="email" required>
        </div>
        <div class="field">
          <label for="telefon">Telefon</label>
          <input id="telefon" name="telefon" data-label="Telefon" type="tel">
        </div>
      </div>
      <div class="row2">
        <div class="field">
          <label for="lekce">Vyber lekci</label>
          <select id="lekce" name="lekce" data-label="Lekce" required>
            <option value="" selected disabled>Vyber z možností…</option>
            <option>Středa 17:00 – Funkční trénink</option>
            <option>Pátek 9:00 – Core &amp; mobilita</option>
            <option>Neděle 17:00 – Silový trénink</option>
            <option>Individuální trénink</option>
          </select>
        </div>
        <div class="field">
          <label for="datum">Preferovaný termín</label>
          <input id="datum" name="datum" data-label="Termín" type="date">
        </div>
      </div>
      <div class="field">
        <label for="pozn">Poznámka (nepovinné)</label>
        <textarea id="pozn" name="pozn" data-label="Poznámka" placeholder="Např. jestli přijdeš s dětmi, na co se chceš zaměřit…"></textarea>
      </div>
      <button class="btn btn-primary submit" type="submit">Odeslat přihlášku</button>
      <p class="hint">Odesláním se otevře tvůj e-mailový klient s předvyplněnou zprávou. Můžeš mi také rovnou napsat do <a href="{{ site.contact.whatsapp }}" target="_blank" rel="noopener">WhatsApp skupiny</a>.</p>
    </form>
  </div>
</section>
