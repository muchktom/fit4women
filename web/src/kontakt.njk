---
layout: base.njk
active: kontakt
title: "Kontakt – cvičení pro ženy Újezd nad Lesy a Koloděje | FIT4WOMEN"
description: "Kontakt na Petru Váňovou (FIT4WOMEN) – telefon, e-mail, WhatsApp skupina. Cvičíme na hřišti SportsField v Újezdě nad Lesy a v tělocvičně v Kolodějích."
---
{% import "components.njk" as c %}

{{ c.pageHero("Ozvi se mi", "Máš chuť cvičit s FIT4WOMEN, nebo se chceš na něco zeptat? Napiš, zavolej, nebo se přidej do naší WhatsApp skupiny.") }}

<section class="bg-white">
  <div class="wrap">
    <div class="contact-cards">
      {% call c.contactCard("Telefon", "Zavolej mi", site.contact.phoneHref, site.contact.phone) %}
        <svg viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"/></svg>
      {% endcall %}
      {% call c.contactCard("E-mail", "Napiš zprávu", "mailto:" + site.contact.email, site.contact.email) %}
        <svg viewBox="0 0 24 24"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/><path d="m22 7-10 6L2 7"/></svg>
      {% endcall %}
      {% call c.contactCard("WhatsApp skupina", "Nejrychlejší cesta k přihlašování na lekce a novinkám", site.contact.whatsapp, "Přidat se do skupiny", true) %}
        <svg viewBox="0 0 24 24"><path d="M21 11.5a8.4 8.4 0 0 1-12 7.6L3 21l1.9-5.9A8.4 8.4 0 1 1 21 11.5Z"/></svg>
      {% endcall %}
    </div>

    {{ c.sectionHead("Tréninky probíhají na těchto sportovištích", "", "Kde cvičíme", true) }}
    <div class="maps">
      {{ c.mapEmbed("Újezd nad Lesy, hřiště SportsField, ul. Polesná", "16156084887916456506", "FIT4WOMEN, SportsField Újezd nad Lesy") }}
      {{ c.mapEmbed("Koloděje, tělocvična TJ Slavoj, V Lipách 135", "16833574294476878146", "FIT4WOMEN, tělocvična Koloděje") }}
    </div>
    <p class="center" style="margin-top:14px;font-size:.9rem;color:var(--muted)">
      Páteční lekce také na hřišti Oplanská (Druhanická × Oplanská, Újezd nad Lesy).
    </p>
  </div>
</section>

