        <div class="small">Nejrychlejší cesta k přihlašování na lekce a novinkám</div>
        <a class="btn btn-primary btn-sm" href="{{ site.contact.whatsapp }}" target="_blank" rel="noopener">Přidat se do skupiny</a>
      </div>
    </div>

    <div class="section-head" style="margin-bottom:24px">
